{
  "name": "shopverse-backend",
  "version": "1.0.0",
  "description": "ShopVerse E-Commerce Backend API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "security-check": "npm audit",
    "profile": "node --prof src/app.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.9.0",
    "redis": "^4.6.7",
    "amqplib": "^0.10.3",
    "stripe": "^13.11.0",
    "nodemailer": "^6.9.4",
    "multer": "^1.4.5",
    "cloudinary": "^1.38.0",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "express-mongo-sanitize": "^2.2.0",
    "xss": "^1.0.14",
    "crypto": "^1.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.1",
    "supertest": "^6.3.3",
    "eslint": "^8.44.0",
    "prettier": "^3.0.0",
    "@faker-js/faker": "^8.0.2"
  }
}